{
  "tasks": {
    "dev": "rsbuild dev --open",
    "server": "deno run --config server/deno.json --cached-only --node-modules-dir=auto --allow-net --allow-read=package.json,/data --allow-write=/data --allow-env server/main.ts",
    "build": "rsbuild build",
    "preview": "rsbuild preview",
    "test": "deno test --config server/deno.json --node-modules-dir=auto --allow-net --allow-env server.test.ts"
  }
}
