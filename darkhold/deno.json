{
  "tasks": {
    "dev": "rsbuild dev --open",
    "server": "deno run --cached-only --node-modules-dir=manual --allow-net --allow-read=package.json,/data --allow-write=/data --allow-env=ICAL_FEEDS,WEATHER_LATITUDE,WEATHER_LONGITUDE,WEATHER_TIMEZONE,TANDOOR_URL,TANDOOR_DEFAULT_TOKEN,MEAL_ASSISTANT_PRODUCE_CATEGORY,MEAL_ASSISTANT_PRECALCULATION_PATH,MEAL_ASSISTANT_STATUS_PATH,WEATHER_FEATURE_CACHE_PATH,CALENDAR_FEATURE_CACHE_PATH server.ts",
    "build": "rsbuild build",
    "preview": "rsbuild preview",
    "test": "deno test --node-modules-dir=manual --allow-net server.test.ts"
  },
  "nodeModulesDir": "auto"
}
